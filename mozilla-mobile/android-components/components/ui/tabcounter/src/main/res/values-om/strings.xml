<resources>
  <!--
    Message announced to the user when tab tray is selected
    The %1$s will be replaced by the number of opened tabs
  -->
  <string name="mozac_tab_counter_open_tab_tray">Cancaloota Banuuf: %1$s. Cancaloota cufuuf tuqi.</string>
  <!--
    Message announced to the user when tab tray is selected used by a11y services
    The %1$s will be replaced by the number of opened tabs
  -->
  <string name="mozac_open_tab_counter_tab_tray">Cancaloota dhuunfaa hin taane Banaa: %1$s. Cancaloota jijjiiruuf tuqi.</string>
  <!--
    Message announced to the user when the tab counter is selected in private browsing mode.
    Used by a11y services. The %1$s will be replaced by the number of opened tabs
  -->
  <string name="mozac_tab_counter_private">Cancaloota Dhuunfaa Banaa: %1$s. Cancaloota cufuuf tuqi.</string>
</resources>
