<resources>
  <!-- The button that appears at the bottom of an error page. -->
  <string name="mozac_browser_errorpages_page_refresh">Irra Deebiin Yaali</string>
  <!-- The document title and heading of an error page shown when a website cannot be loaded for an unknown reason. -->
  <string name="mozac_browser_errorpages_generic_title">Gaaffii Guutuutti Raawwachuu Hin Danda\'u</string>
  <!-- The error message shown when a website cannot be loaded for an unknown reason. -->
  <string name="mozac_browser_errorpages_generic_message"><![CDATA[<p>Odeeffannoon dabalataa waa\'ee rakkoo ykn dogongora kanaa yeroo ammaa hin jiru.</p>]]></string>
  <!-- The document title and heading of the error page shown when a website sends back unusual and incorrect credentials for an SSL certificate. -->
  <string name="mozac_browser_errorpages_security_ssl_title">Walitti Hidhamiinsa Nageenyaa Kufe</string>
  <!-- The error message shown when a website sends back unusual and incorrect credentials for an SSL certificate. -->
  <string name="mozac_browser_errorpages_security_ssl_message"><![CDATA[<ul>\n<li>Fuulli ati ilaaluuf yaaltu dhugummaan daataa fudhatamee mirkanaa\'uu waan hin dandeenyeef mul\'achuu hin danda\'u.</li>\n<li>Maaloo abbootii qabeenyaa weeb saayitii kanaa qunnamaa rakkoo kana isaan beeksisaa.</li>\n</ul>]]></string>
  <!-- The document title and heading of the error page shown when a website sends has an invalid or expired SSL certificate. -->
  <string name="mozac_browser_errorpages_security_bad_cert_title">Walitti Hidhamiinsa Nageenyaa Kufe</string>
  <!-- The error message shown when a website sends has an invalid or expired SSL certificate. -->
  <string name="mozac_browser_errorpages_security_bad_cert_message"><![CDATA[<ul>\n<li>Kun rakkoo qindeessaa sarvarii ta’uu danda’a, ykn nama sarvarii fakkeessuuf yaalu ta’uu danda’a.</li>\n<li>Yoo yeroo darbe milkaa\'inaan sarvarii kanaan wal qunnamte, dogongorri yeroodhaaf ta\'uu danda\'a, booda irra deebitee yaaluun ni danda\'ama.</li>\n</ul>]]></string>
  <!-- The text shown inside the advanced button used to expand the advanced options. It's only shown when a website has an invalid SSL certificate. -->
  <string name="mozac_browser_errorpages_security_bad_cert_advanced">Hammayyaa\'aa…</string>
  <!-- The advanced certificate information shown when a website sends has an invalid SSL certificate. The %1$s will be replaced by the app name and %2$s will be replaced by website URL. It's only shown when a website has an invalid SSL certificate. -->
  <string name="mozac_browser_errorpages_security_bad_cert_techInfo"><![CDATA[<label>Namni tokko marsariiticha fakkeessuuf yaalaa jiraachuu danda\'a ati itti fufuu hin qabdu.</label> <br><br>\n<label>Weebsaayitoonni eenyummaa isaanii karaa ragaalee mirkaneessa. %1$s <b>%2$s</b> hin amanan, sababni isaas kennaan ragaa isaa hin beekamu, ragaan ofumaan mallatteesse, ykn sarvarichi ragaalee gidduugaleessaa sirrii hin ergu.</label>]]></string>
  <!-- The text shown inside the advanced options button used to go back. It's only shown if the user has expanded the advanced options. -->
  <string name="mozac_browser_errorpages_security_bad_cert_back">Duubatti Deebi\'i (Kan Furmaataa)</string>
  <!-- The text shown inside the advanced options button used to bypass the invalid SSL certificate. It's only shown if the user has expanded the advanced options. -->
  <string name="mozac_browser_errorpages_security_bad_cert_accept_temporary">Balaa Fudhadhuu Itti Fufa</string>
  <!-- The document title and heading of the error page shown when a website uses HSTS. -->
  <string name="mozac_browser_errorpages_security_bad_hsts_cert_title">Weeb saayitiin kun walitti dhufeenya nageenya qabu barbaada.</string>
  <!-- The error message shown when a website uses HSTS. -->
  <string name="mozac_browser_errorpages_security_bad_hsts_cert_message"><![CDATA[<ul>\n<li>Fuulli ati ilaaluuf yaaltu mul\'ifamuu hin danda\'u, sababni isaas marsariitiin kun walqunnama nageenya qabu barbaada.</li>\n<li>Dhimmi kun yerdanee kan marsariitii wajjin walqabatu yoo ta\'u, furuuf wanti ati gochuu dandeessu hin jiru.</li>\n<li>Waa’ee rakkoo kanaa bulchaa marsariitichaa beeksisuu dandeessa.</li>\n</ul>]]></string>
  <!-- The text shown inside the advanced button used to expand the advanced options. It's only shown when a website uses HSTS. -->
  <string name="mozac_browser_errorpages_security_bad_hsts_cert_advanced">Hammayyaa\'aa…</string>
  <!-- The advanced certificate information shown when a website uses HSTS. The %1$s will be replaced by the website URL and %2$s will be replaced by the app name. It's only shown when a website uses HSTS. -->
  <string name="mozac_browser_errorpages_security_bad_hsts_cert_techInfo2"><![CDATA[<label> <b>%1$s</b> imaammata nageenyaa HTTP Strict Transport Security (HSTS) jedhamu qaba, kana jechuun <b>%2$s</b> nageenya qofaan walitti hidhuu danda\'a. Marsariitii kana daawwachuuf ala ta’e dabaluu hin dandeessu. </label>Adda fageenya mallattoolee addaan baasuu]]></string>
  <!-- The text shown inside the advanced options button used to go back. It's only shown if the user has expanded the advanced options. -->
  <string name="mozac_browser_errorpages_security_bad_hsts_cert_back">Duubatti Deebi\'aa</string>
  <!-- The document title and heading of the error page shown when the user's network connection is interrupted while connecting to a website. -->
  <string name="mozac_browser_errorpages_net_interrupt_title">Walitti hidhamiinsi addaan cite</string>
  <!-- The error message shown when the user's network connection is interrupted while connecting to a website. -->
  <string name="mozac_browser_errorpages_net_interrupt_message"><![CDATA[<p>Biroowseriin milkaa\'inaan walqunnamsiise, garuu yeroo odeeffannoo dabarsuu walitti hidhamiinsi addaan cite. Mee irra deebi\'ii yaali.</p>\n<ul>\n<li>Saayitiin yeroodhaaf hin argamne ykn baay\'ee sukukkuluu danda\'a. Yeroo muraasa booda irra deebi\'ii yaali.</li>\n<li>Yoo fuula kamiyyuu fe’uu hin dandeenye, deetaa meeshaa keetii ykn walitti hidhamiinsa Wi-Fi ilaali.</li>\n</ul>]]></string>
  <!-- The document title and heading of the error page shown when a website takes too long to load. -->
  <string name="mozac_browser_errorpages_net_timeout_title">Qunnamticha yeroo itti darbe</string>
  <!-- The error message shown when a website took long to load. -->
  <string name="mozac_browser_errorpages_net_timeout_message"><![CDATA[<p>Saayitiin gaafatame gaaffii walitti hidhamiinsaaf deebii hin kennine akkasuma biraawzariin deebii eeguu dhaabeera.</p>\n<ul>\n<li>Sarvarichi fedhii guddaa qabaachuu danda\'aa ykn yeroodhaaf addaan haa cituu? Booda irra deebi\'ii yaali.</li>\n<li>Marsariitiiwwan biroo daawwachuu hin dandeessu? Walitti hidhamiinsa networkii meeshaa sanaa ilaali.</li>\n<li>Meeshaan ykn networkiin keessan firewall ykn proxy tiin eegamaa jiraa? Sajoon sirrii hin taane daawwannaa Weebii gidduu seenuu danda\'a.</li>\n<li>Ammallee rakkina qabdaa? Gargaarsa argachuuf bulchaa networkii ykn dhiyeessaa interneetii kee mariisisi.</li>\n</ul>]]></string>
  <!-- The document title and heading of the error page shown when a website could not be reached. -->
  <string name="mozac_browser_errorpages_connection_failure_title">Qunnamuu hin milkoofne</string>
  <!-- The error message shown when a website could not be reached. -->
  <string name="mozac_browser_errorpages_connection_failure_message"><![CDATA[<ul>\n<li>Saayitiin yeroodhaaf hin argamne ykn garmalee hojiin itti baay\'achuu danda\'a. Yeroo muraasa booda irra deebi\'ii yaali.</li>\n<li>Yoo fuula kamiyyuu fe’uu hin dandeenye, daataa meeshaa keetii ykn walitti hidhamiinsa Wi-Fi ilaali.</li>\n</ul>]]></string>
  <!-- The document title and heading of the error page shown when a website responds in an unexpected way and the browser cannot continue. -->
  <string name="mozac_browser_errorpages_unknown_socket_type_title">Deebii hin eegamne sarvarii irraa</string>
  <!-- The error message shown when a website responds in an unexpected way and the browser cannot continue. -->
  <string name="mozac_browser_errorpages_unknown_socket_type_message"><![CDATA[<p>Saayitiin gaaffii networkii haala hin eegamneen deebii kenne, biraawzariin itti fufuu hin danda\'u.</p>]]></string>
  <!-- The document title and heading of the error page shown when the browser gets stuck in an infinite loop when loading a website. -->
  <string name="mozac_browser_errorpages_redirect_loop_title">Fuulbarruun sirnaan qajeelaa hin jiru</string>
  <!-- The error message shown when the browser gets stuck in an infinite loop when loading a website. -->
  <string name="mozac_browser_errorpages_redirect_loop_message"><![CDATA[<p>Biraawzariin wanta gaafatame deebisuuf yaaluu dhaabeera. Marsariitichi gaaffii haala yoomiyyuu hin xumuramneen qajeelchaa jira.</p>\n<ul>\n<li>Kukiiwwan marsariitii kanaan barbaadan hojii irraa oolchiteetta ykn uggurtteetta?</li>\n<li>Yoo kukiiwwan marsariitichaa fudhachuun rakkinicha hin furre, dhimma qindeessaa sarvarii malee meeshaa kee miti.</li>\n</ul>]]></string>
  <!-- The document title and heading of the error page shown when a website cannot be loaded because the browser is in offline mode. -->
  <string name="mozac_browser_errorpages_offline_title">Haala Sarara Alaa</string>
  <!-- The error message shown when a website cannot be loaded because the browser is in offline mode. -->
  <string name="mozac_browser_errorpages_offline_message"><![CDATA[<p>Biraawzariin haalata sararaa alaa isaatiin hojjechaa waan jiruuf wanta gaafatame waliin walqunnamsiisuu hin danda\'u.</p>\n<ul>\n<li>Meeshaan kun neetworkii hojiirra hin jirreen walqabatee jiraa?</li>\n<li>Gara haalata toora interneetii jijjiiruun fuula irra deebi’anii fe’uuf gadi qabuun “Irra deebi’uun yaali”.</li>\n</ul>]]></string>
  <!-- The document title and heading of the error page shown when the browser prevents loading a website on a restricted port. -->
  <string name="mozac_browser_errorpages_port_blocked_title">Buufata doonii sababa nageenyaatiin daangeffame</string>
  <!-- The error message shown when the browser prevents loading a website on a restricted port. -->
  <string name="mozac_browser_errorpages_port_blocked_message"><![CDATA[<p>Teessoon gaafatame buufata ifteessa (fkn, <q>mozilla.org:80</q> buufata 80 mozilla.org irratti) akka idileetti kaayyoowwan <em>kan biroo</em> Web biraawzingi caalaa. Biraawzarichi gaaffii eegumsaa fi nageenya keessaniif haqeera.</p>]]></string>
  <!-- The document title and heading of the error page shown when the Internet connection is disrupted while loading a website. -->
  <string name="mozac_browser_errorpages_net_reset_title">Walitti hidhamiinsi sun deebi\'ee haaromfame</string>
  <!-- The error message shown when the Internet connection is disrupted while loading a website. -->
  <string name="mozac_browser_errorpages_net_reset_message"><![CDATA[<p>Hidhiin networkii osoo walitti hidhamiinsa irratti mari\'achaa jiruu addaan cite. Mee irra deebi\'ii yaali.</p>\n<ul>\n<li>Saayitiin yeroodhaaf hin argamne ykn garmalee hojiin itti baay\'achuu danda\'a. Yeroo muraasa booda irra deebi\'ii yaali.</li>\n<li>Yoo fuula kamiyyuu fe’uu hin dandeenye, daataa meeshaa keetii ykn walitti hidhamiinsa Wi-Fi ilaali.</li>\n</ul>]]></string>
  <!-- The document title and heading of the error page shown when the browser refuses to load a type of file that is considered unsafe. -->
  <string name="mozac_browser_errorpages_unsafe_content_type_title">Gosa Faayilii Nageenya Hin Qabne</string>
  <!-- The error message shown when the browser refuses to load a type of file that is considered unsafe. -->
  <string name="mozac_browser_errorpages_unsafe_content_type_message"><![CDATA[<ul>\n<li>Maaloo abbootii qabeenyaa weeb saayitii qunnamaa, rakkoo kana isaan beeksisa.</li>\n</ul>]]></string>
  <!-- The document title and heading of the error page shown when a file cannot be loaded because of a detected data corruption. -->
  <string name="mozac_browser_errorpages_corrupted_content_title">Dogoggora Qabiyyee Manca\'e</string>
  <!-- The error message shown when shown when a file cannot be loaded because of a detected data corruption. -->
  <string name="mozac_browser_errorpages_corrupted_content_message"><![CDATA[<p>Fuulli ati ilaaluuf yaaltu dogongorri dabarsuu deetaa keessatti waan argameef mul\'ifamuu hin danda\'u.</p>\n<ul>\n<li>Maaloo abbootii qabeenyaa weeb saayitii qunnamaa, rakkoo kana isaan beeksisa.</li>\n</ul>]]></string>
  <!-- The document title and heading of an error page. -->
  <string name="mozac_browser_errorpages_content_crashed_title">Qabiyyee cabaa</string>
</resources>
