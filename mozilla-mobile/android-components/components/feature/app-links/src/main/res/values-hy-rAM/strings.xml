<resources>
  <!-- The tile for the list of external apps to open the link in -->
  <string name="mozac_feature_applinks_open_in">Բացել հետևյալում…</string>
  <!-- The title of the prompt that warns users their normal browsing session is trying to open another app -->
  <string name="mozac_feature_applinks_normal_confirm_dialog_title">Բացել այլ հավելվածում</string>
  <!-- The title of the prompt that warns users their normal browsing session is trying to open another app -->
  <string name="mozac_feature_applinks_normal_confirm_dialog_title_2">Բացե՞լ այս հղումը մեկ այլ հավելվածում։</string>
  <!--
    The title of the prompt with app suffix.
    %s is a placeholder that will be replaced by an app name
  -->
  <string name="mozac_feature_applinks_normal_confirm_dialog_title_with_app_name_2">Բացե՞լ այս հղումը %s հավելվածում։</string>
  <!--
    The title of the prompt that warns users their normal browsing session is trying to open another app
    %s is a placeholder that will be replaced by an app name
  -->
  <string name="mozac_feature_applinks_normal_confirm_dialog_title_with_app_name">Բացել %s-ում</string>
  <!--
    The message of the prompt to confirm with users that they want to open the link in another app
    %s is a placeholder that will be replaced by the app name
  -->
  <string name="mozac_feature_applinks_normal_confirm_dialog_message">Ցանկանու՞մ եք հեռանալ %s-ից՝ այս բովանդակությունը դիտելու համար:</string>
  <!-- Opens the selected time -->
  <string name="mozac_feature_applinks_confirm_dialog_confirm">Բացել</string>
  <!-- Opens the selected app link -->
  <string name="mozac_feature_applinks_confirm_dialog_confirm_2">Բացել հավելվածում</string>
  <!-- Cancels the prompt -->
  <string name="mozac_feature_applinks_confirm_dialog_deny">Չեղարկել</string>
  <!-- The label of the checkbox that, depending of user's choice, can change the Open links in apps setting -->
  <string name="mozac_feature_applinks_confirm_dialog_checkbox_label">Միշտ բացել հղումները հավելվածներում</string>
  <!-- The label for the expandable section that shows additional details -->
  <string name="mozac_feature_applinks_view_details">Դիտել մանրամասները</string>
  <!-- The label for the expandable section when details are shown -->
  <string name="mozac_feature_applinks_hide_details">Թաքցնել մանրամասները</string>
  <!-- The label for the source URL in the details section -->
  <string name="mozac_feature_applinks_source_url">Աղբյուրի URL</string>
  <!-- The label for the destination URL in the details section -->
  <string name="mozac_feature_applinks_destination_url">Նպատակակետի URL</string>
  <!-- The label for the URL if opening in the browser in the details section. %s is the browser name. -->
  <string name="mozac_feature_applinks_firefox_url">URL-ը, եթե բացվում է %s-ում</string>
  <!-- The label for the unique identifier in the details section -->
  <string name="mozac_feature_applinks_unique_identifier">Միակ նույնականացուցիչ</string>
  <!-- The text shown when there is no Firefox URL -->
  <string name="mozac_feature_applinks_none">Չկա</string>
  <!-- The subtitle showing where the link was navigated from. %s is the domain. -->
  <string name="mozac_feature_applinks_link_from">Հղում %s-ից</string>
</resources>
