<resources xmlns:tools="http://schemas.android.com/tools" xmlns:moz="http://mozac.org/tools">
  <!-- The tile for the list of external apps to open the link in -->
  <string name="mozac_feature_applinks_open_in">Megnyitás a következővel…</string>
  <!-- The description to warn users that their private browsing session changes -->
  <string name="mozac_feature_applinks_confirm_dialog_title" tools:ignore="UnusedResources" moz:removedIn="150">Megnyitja az alkalmazásban? Lehet, hogy tevékenysége már nem lesz privát.</string>
  <!--
    The description to warn users that their private browsing session changes
    %s is a placeholder that will be replaced by an app name
  -->
  <string name="mozac_feature_applinks_confirm_dialog_title_with_app_name" tools:ignore="UnusedResources" moz:removedIn="150">Megnyitja ebben: %s? Lehet, hogy tevékenysége már nem lesz privát.</string>
  <!-- The title of the prompt that warns users their normal browsing session is trying to open another app -->
  <string name="mozac_feature_applinks_normal_confirm_dialog_title">Megnyitás egy másik alkalmazásban</string>
  <!--
    The title of the prompt that warns users their normal browsing session is trying to open another app
    %s is a placeholder that will be replaced by an app name
  -->
  <string name="mozac_feature_applinks_normal_confirm_dialog_title_with_app_name">Megnyitás ezzel: %s</string>
  <!--
    The message of the prompt to confirm with users that they want to open the link in another app
    %s is a placeholder that will be replaced by the app name
  -->
  <string name="mozac_feature_applinks_normal_confirm_dialog_message">Elhagyja a %sot a tartalom megtekintéséhez?</string>
  <!-- Opens the selected time -->
  <string name="mozac_feature_applinks_confirm_dialog_confirm">Megnyitás</string>
  <!-- Cancels the prompt -->
  <string name="mozac_feature_applinks_confirm_dialog_deny">Mégse</string>
  <!-- The label of the checkbox that, depending of user's choice, can change the Open links in apps setting -->
  <string name="mozac_feature_applinks_confirm_dialog_checkbox_label">Mindig alkalmazásokban nyissa meg a hivatkozásokat</string>
  <!-- The label for the expandable section that shows additional details -->
  <string name="mozac_feature_applinks_view_details">Részletek megtekintése</string>
  <!-- The label for the expandable section when details are shown -->
  <string name="mozac_feature_applinks_hide_details">Részletek elrejtése</string>
  <!-- The label for the source URL in the details section -->
  <string name="mozac_feature_applinks_source_url">Forráswebcím</string>
  <!-- The label for the destination URL in the details section -->
  <string name="mozac_feature_applinks_destination_url">Célwebcím</string>
  <!-- The label for the URL if opening in the browser in the details section. %s is the browser name. -->
  <string name="mozac_feature_applinks_firefox_url">Webcím, ha a %sban nyílik meg</string>
  <!-- The label for the unique identifier in the details section -->
  <string name="mozac_feature_applinks_unique_identifier">Egyedi azonosító</string>
  <!-- The text shown when there is no Firefox URL -->
  <string name="mozac_feature_applinks_none">Nincs</string>
</resources>
