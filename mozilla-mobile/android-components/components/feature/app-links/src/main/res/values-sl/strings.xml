<resources xmlns:tools="http://schemas.android.com/tools" xmlns:moz="http://mozac.org/tools">
  <!-- The tile for the list of external apps to open the link in -->
  <string name="mozac_feature_applinks_open_in">Odpri v …</string>
  <!-- The description to warn users that their private browsing session changes -->
  <string name="mozac_feature_applinks_confirm_dialog_title" tools:ignore="UnusedResources" moz:removedIn="150">Odprem v aplikaciji? Vaša dejavnost morda ne bo več zasebna.</string>
  <!--
    The description to warn users that their private browsing session changes
    %s is a placeholder that will be replaced by an app name
  -->
  <string name="mozac_feature_applinks_confirm_dialog_title_with_app_name" tools:ignore="UnusedResources" moz:removedIn="150">Odprem v aplikaciji %s? Vaša dejavnost morda ne bo več zasebna.</string>
  <!-- The title of the prompt that warns users their normal browsing session is trying to open another app -->
  <string name="mozac_feature_applinks_normal_confirm_dialog_title">Odpiranje v drugi aplikaciji</string>
  <!--
    The title of the prompt that warns users their normal browsing session is trying to open another app
    %s is a placeholder that will be replaced by an app name
  -->
  <string name="mozac_feature_applinks_normal_confirm_dialog_title_with_app_name">Odpri v aplikaciji %s</string>
  <!--
    The message of the prompt to confirm with users that they want to open the link in another app
    %s is a placeholder that will be replaced by the app name
  -->
  <string name="mozac_feature_applinks_normal_confirm_dialog_message">Ali želite za ogled te vsebine zapustiti %s?</string>
  <!-- Opens the selected time -->
  <string name="mozac_feature_applinks_confirm_dialog_confirm">Odpri</string>
  <!-- Cancels the prompt -->
  <string name="mozac_feature_applinks_confirm_dialog_deny">Prekliči</string>
  <!-- The label of the checkbox that, depending of user's choice, can change the Open links in apps setting -->
  <string name="mozac_feature_applinks_confirm_dialog_checkbox_label">Vedno odpiraj povezave v aplikacijah</string>
  <!-- The label for the expandable section that shows additional details -->
  <string name="mozac_feature_applinks_view_details">Prikaži podrobnosti</string>
  <!-- The label for the expandable section when details are shown -->
  <string name="mozac_feature_applinks_hide_details">Skrij podrobnosti</string>
</resources>
