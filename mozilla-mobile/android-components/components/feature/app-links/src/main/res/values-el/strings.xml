  <string name="mozac_feature_applinks_confirm_dialog_checkbox_label">Πάντα άνοιγμα συνδέσμων σε εφαρμογές</string>
  <!-- The label for the expandable section that shows additional details -->
  <string name="mozac_feature_applinks_view_details">Προβολή λεπτομερειών</string>
  <!-- The label for the expandable section when details are shown -->
  <string name="mozac_feature_applinks_hide_details">Απόκρυψη λεπτομερειών</string>
  <!-- The label for the source URL in the details section -->
  <string name="mozac_feature_applinks_source_url">URL πηγής</string>
  <!-- The label for the destination URL in the details section -->
  <string name="mozac_feature_applinks_destination_url">URL προορισμού</string>
  <!-- The label for the URL if opening in the browser in the details section. %s is the browser name. -->
  <string name="mozac_feature_applinks_firefox_url">Το URL, αν ανοίγει στο %s</string>
  <!-- The label for the unique identifier in the details section -->
  <string name="mozac_feature_applinks_unique_identifier">Μοναδικό αναγνωριστικό</string>
  <!-- The text shown when there is no Firefox URL -->
  <string name="mozac_feature_applinks_none">Κανένα</string>
  <!-- The subtitle showing where the link was navigated from. %s is the domain. -->
  <string name="mozac_feature_applinks_link_from">Σύνδεσμος από %s</string>
