<resources xmlns:tools="http://schemas.android.com/tools" xmlns:moz="http://mozac.org/tools">
  <!-- The tile for the list of external apps to open the link in -->
  <string name="mozac_feature_applinks_open_in">Öffnen in…</string>
  <!-- The description to warn users that their private browsing session changes -->
  <string name="mozac_feature_applinks_confirm_dialog_title" tools:ignore="UnusedResources" moz:removedIn="150">In App öffnen? Ihre Aktivitäten sind dann möglicherweise nicht mehr privat.</string>
  <!--
    The description to warn users that their private browsing session changes
    %s is a placeholder that will be replaced by an app name
  -->
  <string name="mozac_feature_applinks_confirm_dialog_title_with_app_name" tools:ignore="UnusedResources" moz:removedIn="150">In %s öffnen? Ihre Aktivitäten sind dann möglicherweise nicht mehr privat.</string>
  <!-- The title of the prompt that warns users their normal browsing session is trying to open another app -->
  <string name="mozac_feature_applinks_normal_confirm_dialog_title">In einer anderen App öffnen</string>
  <!--
    The title of the prompt that warns users their normal browsing session is trying to open another app
    %s is a placeholder that will be replaced by an app name
  -->
  <string name="mozac_feature_applinks_normal_confirm_dialog_title_with_app_name">In %s öffnen</string>
  <!--
    The message of the prompt to confirm with users that they want to open the link in another app
    %s is a placeholder that will be replaced by the app name
  -->
  <string name="mozac_feature_applinks_normal_confirm_dialog_message">Möchten Sie %s verlassen, um diesen Inhalt anzuzeigen?</string>
  <!-- Opens the selected time -->
  <string name="mozac_feature_applinks_confirm_dialog_confirm">Öffnen</string>
  <!-- Cancels the prompt -->
  <string name="mozac_feature_applinks_confirm_dialog_deny">Abbrechen</string>
  <!-- The label of the checkbox that, depending of user's choice, can change the Open links in apps setting -->
  <string name="mozac_feature_applinks_confirm_dialog_checkbox_label">Links in Apps immer öffnen</string>
  <!-- The label for the expandable section that shows additional details -->
  <string name="mozac_feature_applinks_view_details">Details anzeigen</string>
  <!-- The label for the expandable section when details are shown -->
  <string name="mozac_feature_applinks_hide_details">Details ausblenden</string>
  <!-- The label for the source URL in the details section -->
  <string name="mozac_feature_applinks_source_url">Quell-URL</string>
  <!-- The label for the destination URL in the details section -->
  <string name="mozac_feature_applinks_destination_url">Ziel-URL</string>
  <!-- The label for the URL if opening in the browser in the details section. %s is the browser name. -->
  <string name="mozac_feature_applinks_firefox_url">URL beim Öffnen in %s</string>
  <!-- The label for the unique identifier in the details section -->
  <string name="mozac_feature_applinks_unique_identifier">Eindeutiger Identifikator</string>
  <!-- The text shown when there is no Firefox URL -->
  <string name="mozac_feature_applinks_none">Keine</string>
</resources>
