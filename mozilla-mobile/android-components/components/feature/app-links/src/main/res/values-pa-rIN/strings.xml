<resources>
  <!-- The tile for the list of external apps to open the link in -->
  <string name="mozac_feature_applinks_open_in">…ਨਾਲ ਖੋਲ੍ਹੋ</string>
  <!-- The title of the prompt that warns users their normal browsing session is trying to open another app -->
  <string name="mozac_feature_applinks_normal_confirm_dialog_title">ਹੋਰ ਐਪ ਵਿੱਚ ਖੋਲ੍ਹੋ</string>
  <!-- The title of the prompt that warns users their normal browsing session is trying to open another app -->
  <string name="mozac_feature_applinks_normal_confirm_dialog_title_2">ਇਸ ਲਿੰਕ ਨੂੰ ਹੋਰ ਐਪ ਵਿੱਚ ਖੋਲ੍ਹਣਾ ਹੈ?</string>
  <!--
    The title of the prompt with app suffix.
    %s is a placeholder that will be replaced by an app name
  -->
  <string name="mozac_feature_applinks_normal_confirm_dialog_title_with_app_name_2">ਇਸ ਲਿੰਕ ਨੂੰ %s ਐਪ ਵਿੱਚ ਖੋਲ੍ਹਣਾ ਹੈ?</string>
  <!--
    The title of the prompt that warns users their normal browsing session is trying to open another app
    %s is a placeholder that will be replaced by an app name
  -->
  <string name="mozac_feature_applinks_normal_confirm_dialog_title_with_app_name">%s ਵਿੱਚ ਖੋਲ੍ਹੋ</string>
  <!--
    The message of the prompt to confirm with users that they want to open the link in another app
    %s is a placeholder that will be replaced by the app name
  -->
  <string name="mozac_feature_applinks_normal_confirm_dialog_message">ਕੀ ਤੁਸੀਂ ਇਹ ਸਮੱਗਰੀ ਵੇਖਣ ਲਈ %s ਤੋਂ ਬਾਹਰ ਜਾਣਾ ਚਾਹੁੰਦੇ ਹੋ?</string>
  <!-- Opens the selected time -->
  <string name="mozac_feature_applinks_confirm_dialog_confirm">ਖੋਲ੍ਹੋ</string>
  <!-- Opens the selected app link -->
  <string name="mozac_feature_applinks_confirm_dialog_confirm_2">ਐਪ ਵਿੱਚ ਖੋਲ੍ਹੋ</string>
  <!-- Cancels the prompt -->
  <string name="mozac_feature_applinks_confirm_dialog_deny">ਰੱਦ ਕਰੋ</string>
  <!-- The label of the checkbox that, depending of user's choice, can change the Open links in apps setting -->
  <string name="mozac_feature_applinks_confirm_dialog_checkbox_label">ਲਿੰਕ ਨੂੰ ਹਮੇਸ਼ਾਂ ਐਪਾਂ ਵਿੱਚ ਖੋਲ੍ਹੋ</string>
  <!-- The label for the expandable section that shows additional details -->
  <string name="mozac_feature_applinks_view_details">ਵੇਰਵਿਆਂ ਨੂੰ ਵੇਖੋ</string>
  <!-- The label for the expandable section when details are shown -->
  <string name="mozac_feature_applinks_hide_details">ਵੇਰਵਿਆਂ ਨੂੰ ਲੁਕਾਓ</string>
  <!-- The label for the source URL in the details section -->
  <string name="mozac_feature_applinks_source_url">ਸਰੋਤ URL</string>
  <!-- The label for the destination URL in the details section -->
  <string name="mozac_feature_applinks_destination_url">ਟਿਕਾਣਾ URL</string>
  <!-- The label for the URL if opening in the browser in the details section. %s is the browser name. -->
  <string name="mozac_feature_applinks_firefox_url">ਜੇ %s ਵਿੱਚ ਖੁੱਲ੍ਹ ਰਿਹਾ ਹੈ ਤਾਂ URL</string>
  <!-- The label for the unique identifier in the details section -->
  <string name="mozac_feature_applinks_unique_identifier">ਵਿਲੱਖਣ ਪਛਾਣਕਰਤਾ</string>
  <!-- The text shown when there is no Firefox URL -->
  <string name="mozac_feature_applinks_none">ਕੋਈ ਨਹੀਂ</string>
  <!-- The subtitle showing where the link was navigated from. %s is the domain. -->
  <string name="mozac_feature_applinks_link_from">%s ਤੋਂ ਲਿੰਕ</string>
</resources>
