<resources>
  <!-- The tile for the list of external apps to open the link in -->
  <string name="mozac_feature_applinks_open_in">ئېچىش…</string>
  <!-- The title of the prompt that warns users their normal browsing session is trying to open another app -->
  <string name="mozac_feature_applinks_normal_confirm_dialog_title">باشقا ئەپتە ئاچ</string>
  <!-- The title of the prompt that warns users their normal browsing session is trying to open another app -->
  <string name="mozac_feature_applinks_normal_confirm_dialog_title_2">بۇ ئۇلانمىنى باشقا ئەپتە ئاچامدۇ؟</string>
  <!--
    The title of the prompt with app suffix.
    %s is a placeholder that will be replaced by an app name
  -->
  <string name="mozac_feature_applinks_normal_confirm_dialog_title_with_app_name_2">بۇ ئۇلانمىنى %s ئەپتە ئاچامدۇ؟</string>
  <!--
    The title of the prompt that warns users their normal browsing session is trying to open another app
    %s is a placeholder that will be replaced by an app name
  -->
  <string name="mozac_feature_applinks_normal_confirm_dialog_title_with_app_name">%s دا ئاچ</string>
  <!--
    The message of the prompt to confirm with users that they want to open the link in another app
    %s is a placeholder that will be replaced by the app name
  -->
  <string name="mozac_feature_applinks_normal_confirm_dialog_message">بۇ مەزمۇننى كۆرۈش ئۈچۈن %s دىن ئايرىلامسىز؟</string>
  <!-- Opens the selected time -->
  <string name="mozac_feature_applinks_confirm_dialog_confirm">ئاچ</string>
  <!-- Opens the selected app link -->
  <string name="mozac_feature_applinks_confirm_dialog_confirm_2">ئەپتە ئاچ</string>
  <!-- Cancels the prompt -->
  <string name="mozac_feature_applinks_confirm_dialog_deny">ۋاز كەچ</string>
  <!-- The label of the checkbox that, depending of user's choice, can change the Open links in apps setting -->
  <string name="mozac_feature_applinks_confirm_dialog_checkbox_label">ئۇلانمىنى ھەمىشە ئەپتە ئاچ</string>
  <!-- The label for the expandable section that shows additional details -->
  <string name="mozac_feature_applinks_view_details">تەپسىلاتىنى كۆرسەت</string>
  <!-- The label for the expandable section when details are shown -->
  <string name="mozac_feature_applinks_hide_details">تەپسىلاتىنى يوشۇر</string>
  <!-- The label for the source URL in the details section -->
  <string name="mozac_feature_applinks_source_url">مەنبە تور ئادرېسى</string>
  <!-- The label for the destination URL in the details section -->
  <string name="mozac_feature_applinks_destination_url">نىشان تور ئادرېسى</string>
  <!-- The label for the URL if opening in the browser in the details section. %s is the browser name. -->
  <string name="mozac_feature_applinks_firefox_url">ئەگەر تور ئادرېسى %s دا ئېچىلسا</string>
  <!-- The label for the unique identifier in the details section -->
  <string name="mozac_feature_applinks_unique_identifier">بىردىنبىر پەرقلەندۈرگۈچ</string>
  <!-- The text shown when there is no Firefox URL -->
  <string name="mozac_feature_applinks_none">يوق</string>
