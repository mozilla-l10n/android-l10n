  <string name="mozac_feature_applinks_normal_confirm_dialog_title_2">Opna þennan tengil í öðru forriti?</string>
  <!--
    The title of the prompt with app suffix.
    %s is a placeholder that will be replaced by an app name
  -->
  <string name="mozac_feature_applinks_normal_confirm_dialog_title_with_app_name_2">Opna þennan tengil í %s forritinu?</string>
