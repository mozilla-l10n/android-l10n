<resources>
  <!-- Title shown in the protection dashboard indicating the user is protected -->
  <string name="mozac_protections_dashboard_youre_protected">Ви захищені</string>
  <plurals name="mozac_protections_dashboard_trackers_blocked_this_week">
    <!--
      Label shown below the tracker count in the dashboard. The count is displayed separately
      above this string and is used to select the correct plural form. Do not include the number in
      the translation.
    -->
    <item quantity="one">Вистежувач заблоковано цього тижня</item>
    <item quantity="few">Вистежувачі заблоковано цього тижня</item>
    <item quantity="other">Вистежувачів заблоковано цього тижня</item>
  </plurals>
  <plurals name="mozac_protections_dashboard_data_saved">
    <!-- Label showing data saved in megabytes. %1$d is the number of MB saved -->
    <item quantity="one">Заощаджено %1$d МБ</item>
    <item quantity="few">Заощаджено %1$d МБ</item>
    <item quantity="other">Заощаджено %1$d МБ</item>
  </plurals>
  <!-- Section header for tracker category breakdown -->
  <string name="protections_dashboard_where_they_came_from">Звідки вони з’явились</string>
  <!-- Tracker category: Advertising trackers -->
  <string name="protections_dashboard_category_ads">Реклама</string>
  <!-- Tracker category: Analytics trackers -->
  <string name="protections_dashboard_category_analytics">Аналітика</string>
  <!-- Tracker category: Social media trackers -->
  <string name="protections_dashboard_category_social">Соціальні мережі</string>
  <!-- Tracker category: Other trackers -->
  <string name="protections_dashboard_category_others">Інше</string>
  <!-- Title shown in the protection dashboard header next to the shield icon -->
  <string name="mozac_protections_dashboard_trackers_blocked_this_week_title">Вистежувачів заблоковано цього тижня</string>
  <!--
    Title shown when no trackers have been blocked yet
    %1$s will be replaced by the app name (e.g. Firefox Focus)
  -->
  <string name="mozac_protections_dashboard_empty_title">%1$s блокує стеження під час перегляду.</string>
  <!-- Subtitle shown when no trackers have been blocked yet -->
  <string name="mozac_protections_dashboard_empty_subtitle">Ви побачите їх тут.</string>
  <plurals name="mozac_protections_dashboard_total_blocked_since_2">
    <!--
      Footer line shown in the dashboard summarizing total trackers blocked
      since a specific date. %1$d is the trackers count number (e.g. 123).
      %2$s is the formatted date (e.g. "February 23, 2026").
    -->
    <item quantity="one">%1$d вистежувач заблоковано з %2$s</item>
    <item quantity="few">%1$d вистежувачі заблоковано з %2$s</item>
    <item quantity="other">%1$d вистежувачів заблоковано з %2$s</item>
  </plurals>
</resources>
