  </plurals>
  <plurals name="mozac_protections_dashboard_data_saved">
    <!-- Label showing data saved in megabytes. %1$d is the number of MB saved -->
    <item quantity="one">%1$d എം.ബി കരുതിവച്ചു</item>
    <item quantity="other">%1$d എം.ബി കരുതിവച്ചു</item>
  </plurals>
  <!-- Section header for tracker category breakdown -->
  <string name="protections_dashboard_where_they_came_from">ഇവ എവിടെ നിന്നാണു വന്നതു്</string>
