  <!-- Tracker category: Other trackers -->
  <string name="protections_dashboard_category_others">മറ്റുള്ളവ</string>
  <!-- Title shown in the protection dashboard header next to the shield icon -->
  <string name="mozac_protections_dashboard_trackers_blocked_this_week_title">ഈ ആഴ്ച തടഞ്ഞ പിന്തുടൎച്ചയന്ത്രങ്ങൾ</string>
  <!--
    Title shown when no trackers have been blocked yet
