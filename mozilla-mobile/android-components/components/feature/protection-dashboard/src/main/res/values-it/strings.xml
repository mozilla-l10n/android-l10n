<resources>
  <!-- Title shown in the protection dashboard indicating the user is protected -->
  <string name="mozac_protections_dashboard_youre_protected">Sei protetto</string>
  <plurals name="mozac_protections_dashboard_trackers_blocked_this_week">
    <!--
      Label shown below the tracker count in the dashboard. The count is displayed separately
      above this string and is used to select the correct plural form. Do not include the number in
      the translation.
    -->
    <item quantity="one">elemento tracciante bloccato questa settimana</item>
    <item quantity="other">elementi traccianti bloccati questa settimana</item>
  </plurals>
  <plurals name="mozac_protections_dashboard_data_saved">
    <!-- Label showing data saved in megabytes. %1$d is the number of MB saved -->
    <item quantity="one">%1$d MB risparmiato</item>
    <item quantity="other">%1$d MB risparmiati</item>
  </plurals>
  <!-- Section header for tracker category breakdown -->
  <string name="protections_dashboard_where_they_came_from">Origine</string>
  <!-- Tracker category: Advertising trackers -->
  <string name="protections_dashboard_category_ads">Pubblicità</string>
  <!-- Tracker category: Analytics trackers -->
  <string name="protections_dashboard_category_analytics">Statistiche</string>
  <!-- Tracker category: Social media trackers -->
  <string name="protections_dashboard_category_social">Social</string>
  <!-- Tracker category: Other trackers -->
  <string name="protections_dashboard_category_others">Altro</string>
  <!-- Title shown in the protection dashboard header next to the shield icon -->
  <string name="mozac_protections_dashboard_trackers_blocked_this_week_title">Elementi traccianti bloccati questa settimana</string>
  <!--
    Title shown when no trackers have been blocked yet
    %1$s will be replaced by the app name (e.g. Firefox Focus)
  -->
  <string name="mozac_protections_dashboard_empty_title">%1$s blocca gli elementi traccianti durante la navigazione.</string>
  <!-- Subtitle shown when no trackers have been blocked yet -->
  <string name="mozac_protections_dashboard_empty_subtitle">Li vedrai qui.</string>
  <plurals name="mozac_protections_dashboard_trackers_count">
    <!--
      Label used for the number of trackers blocked.
      %1$d is the number of trackers.
    -->
    <item quantity="one">%1$d elemento tracciante</item>
    <item quantity="other">%1$d elementi traccianti</item>
  </plurals>
  <plurals name="mozac_protections_dashboard_total_blocked_since">
    <!--
      Footer line shown in the dashboard summarizing total trackers blocked
      since a specific date. %1$s is the trackers count phrase (e.g.
      "5,305 trackers"). %2$s is the formatted date (e.g. "February 23, 2026").
    -->
    <item quantity="one">%1$s bloccato dal %2$s</item>
    <item quantity="other">%1$s bloccati dal %2$s</item>
  </plurals>
</resources>
