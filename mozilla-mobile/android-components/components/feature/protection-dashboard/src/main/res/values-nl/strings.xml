<resources>
  <!-- Title shown in the protection dashboard indicating the user is protected -->
  <string name="mozac_protections_dashboard_youre_protected">U bent beschermd</string>
  <plurals name="mozac_protections_dashboard_trackers_blocked_this_week">
    <!--
      Label shown below the tracker count in the dashboard. The count is displayed separately
      above this string and is used to select the correct plural form. Do not include the number in
      the translation.
    -->
    <item quantity="one">Tracker geblokkeerd deze week</item>
    <item quantity="other">Trackers geblokkeerd deze week</item>
  </plurals>
  <plurals name="mozac_protections_dashboard_data_saved">
    <!-- Label showing data saved in megabytes. %1$d is the number of MB saved -->
    <item quantity="one">%1$d MB opgeslagen</item>
    <item quantity="other">%1$d MB opgeslagen</item>
  </plurals>
  <!-- Section header for tracker category breakdown -->
  <string name="protections_dashboard_where_they_came_from">Waar ze vandaan kwamen</string>
  <!-- Tracker category: Advertising trackers -->
  <string name="protections_dashboard_category_ads">Advertenties</string>
  <!-- Tracker category: Analytics trackers -->
  <string name="protections_dashboard_category_analytics">Analyse</string>
  <!-- Tracker category: Social media trackers -->
  <string name="protections_dashboard_category_social">Sociale</string>
  <!-- Tracker category: Other trackers -->
  <string name="protections_dashboard_category_others">Overige</string>
  <!-- Title shown in the protection dashboard header next to the shield icon -->
  <string name="mozac_protections_dashboard_trackers_blocked_this_week_title">Trackers geblokkeerd deze week</string>
  <!--
    Title shown when no trackers have been blocked yet
    %1$s will be replaced by the app name (e.g. Firefox Focus)
  -->
  <string name="mozac_protections_dashboard_empty_title">%1$s blokkeert trackers terwijl u surft.</string>
  <!-- Subtitle shown when no trackers have been blocked yet -->
  <string name="mozac_protections_dashboard_empty_subtitle">U ziet ze hier.</string>
  <plurals name="mozac_protections_dashboard_total_blocked_since_2">
    <!--
      Footer line shown in the dashboard summarizing total trackers blocked
      since a specific date. %1$d is the trackers count number (e.g. 123).
      %2$s is the formatted date (e.g. "February 23, 2026").
    -->
    <item quantity="one">%1$d tracker geblokkeerd sinds %2$s</item>
    <item quantity="other">%1$d trackers geblokkeerd sinds %2$s</item>
  </plurals>
</resources>
