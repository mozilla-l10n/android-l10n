<resources>
  <!-- Title shown in the protection dashboard indicating the user is protected -->
  <string name="mozac_protections_dashboard_youre_protected">Vous êtes protégé·e</string>
  <plurals name="mozac_protections_dashboard_trackers_blocked_this_week">
    <!--
      Label shown below the tracker count in the dashboard. The count is displayed separately
      above this string and is used to select the correct plural form. Do not include the number in
      the translation.
    -->
    <item quantity="one">Traqueur bloqué cette semaine</item>
    <item quantity="other">Traqueurs bloqués cette semaine</item>
  </plurals>
  <plurals name="mozac_protections_dashboard_data_saved">
    <!-- Label showing data saved in megabytes. %1$d is the number of MB saved -->
    <item quantity="one">%1$d\u00a0Mo économisé</item>
    <item quantity="other">%1$d\u00a0Mo économisés</item>
  </plurals>
  <!-- Section header for tracker category breakdown -->
  <string name="protections_dashboard_where_they_came_from">Leur origine\u00a0?</string>
  <!-- Tracker category: Advertising trackers -->
  <string name="protections_dashboard_category_ads">Publicités</string>
  <!-- Tracker category: Analytics trackers -->
  <string name="protections_dashboard_category_analytics">Statistiques</string>
  <!-- Tracker category: Social media trackers -->
  <string name="protections_dashboard_category_social">Réseaux sociaux</string>
  <!-- Tracker category: Other trackers -->
  <string name="protections_dashboard_category_others">Autres</string>
  <!-- Title shown in the protection dashboard header next to the shield icon -->
  <string name="mozac_protections_dashboard_trackers_blocked_this_week_title">Traqueurs bloqués cette semaine</string>
  <!--
    Title shown when no trackers have been blocked yet
    %1$s will be replaced by the app name (e.g. Firefox Focus)
  -->
  <string name="mozac_protections_dashboard_empty_title">%1$s bloque les traqueurs pendant que vous naviguez.</string>
  <!-- Subtitle shown when no trackers have been blocked yet -->
  <string name="mozac_protections_dashboard_empty_subtitle">Vous les verrez ici.</string>
</resources>
