<resources>
  <!-- Title shown in the protection dashboard indicating the user is protected -->
  <string name="mozac_protections_dashboard_youre_protected">Ești protejat(ă)</string>
  <plurals name="mozac_protections_dashboard_trackers_blocked_this_week">
    <!--
      Label shown below the tracker count in the dashboard. The count is displayed separately
      above this string and is used to select the correct plural form. Do not include the number in
      the translation.
    -->
    <item quantity="one">Element de urmărire blocat în această săptămână</item>
    <item quantity="few">Elemente de urmărire blocate în această săptămână</item>
    <item quantity="other">Elemente de urmărire blocate în această săptămână</item>
  </plurals>
  <plurals name="mozac_protections_dashboard_data_saved">
    <!-- Label showing data saved in megabytes. %1$d is the number of MB saved -->
    <item quantity="one">%1$d MB economisit</item>
    <item quantity="few">%1$d MB economisiți</item>
    <item quantity="other">%1$d MB economisiți</item>
  </plurals>
  <!-- Section header for tracker category breakdown -->
  <string name="protections_dashboard_where_they_came_from">De unde au venit</string>
  <!-- Tracker category: Advertising trackers -->
  <string name="protections_dashboard_category_ads">Reclame</string>
  <!-- Tracker category: Analytics trackers -->
  <string name="protections_dashboard_category_analytics">Date analitice</string>
  <!-- Tracker category: Social media trackers -->
  <string name="protections_dashboard_category_social">Rețele de socializare</string>
  <!-- Tracker category: Other trackers -->
  <string name="protections_dashboard_category_others">Altele</string>
  <!-- Title shown in the protection dashboard header next to the shield icon -->
  <string name="mozac_protections_dashboard_trackers_blocked_this_week_title">Elemente de urmărire blocate în această săptămână</string>
  <!--
    Title shown when no trackers have been blocked yet
    %1$s will be replaced by the app name (e.g. Firefox Focus)
  -->
  <string name="mozac_protections_dashboard_empty_title">%1$s blochează elementele de urmărire în timp ce navighezi.</string>
  <!-- Subtitle shown when no trackers have been blocked yet -->
  <string name="mozac_protections_dashboard_empty_subtitle">Le vei vedea aici.</string>
  <plurals name="mozac_protections_dashboard_total_blocked_since_2">
    <!--
      Footer line shown in the dashboard summarizing total trackers blocked
      since a specific date. %1$d is the trackers count number (e.g. 123).
      %2$s is the formatted date (e.g. "February 23, 2026").
    -->
    <item quantity="one">%1$d element de urmărire blocat din %2$s</item>
    <item quantity="few">%1$d elemente de urmărire blocate din %2$s</item>
    <item quantity="other">%1$d de elemente de urmărire blocate din %2$s</item>
  </plurals>
</resources>
