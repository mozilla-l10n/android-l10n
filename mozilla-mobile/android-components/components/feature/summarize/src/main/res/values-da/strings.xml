<resources>
  <!-- Link text to learn more about downloading Gemini Nano -->
  <string name="mozac_summarize_learn_more_link">Læs mere</string>
  <!-- Title for the off-device shake summarization consent screen. Localization note: Asking if the user wants to use the shake gesture to summarize the page they are viewing. -->
  <string name="mozac_summarize_shake_consent_off_device_title">Sammenfat ved at ryste?</string>
  <!-- Message for the off-device shake summarization consent screen. %1$s is 'Firefox' -->
  <string name="mozac_summarize_shake_consent_off_device_message">Ryst din enhed, få en sammenfatning af en side fra %1$s på få sekunder.</string>
  <!-- Button text for the off-device shake summarization consent screen approving shake consent. Localization note: "Continue" turns on the shake to summarize feature. -->
  <string name="mozac_summarize_shake_consent_off_device_button_positive">Fortsæt</string>
  <!-- Button text for the off-device shake summarization consent screen denying shake consent. Localization note: "Not now" dismisses the request to turn on the shake to summarize feature. -->
  <string name="mozac_summarize_shake_consent_off_device_negative_button">Ikke nu</string>
  <!-- Title for the on-device shake summarization and download consent screen -->
  <string name="mozac_summarize_shake_consent_on_device_title">Sammenfat denne side</string>
  <!-- Message for the on-device shake summarization and download consent screen. %s will be replaced by app name. -->
  <string name="mozac_summarize_shake_consent_on_device_message">Efter en hurtig engangs-filhentning kan %s sammenfatte sider, når du ryster din enhed.</string>
  <!-- Button text for the on-device shake summarization and download consent screen approving shake and download consent -->
  <string name="mozac_summarize_shake_consent_on_device_button_positive">Hent \u0020for at sammenfatte</string>
  <!-- Button text for the on-device shake summarization and download consent screen denying shake and download consent -->
  <string name="mozac_summarize_shake_consent_on_device_negative_button">Ikke nu</string>
  <!-- Title for the download consent screen -->
  <string name="mozac_summarize_download_consent_title">Opsæt private sammendrag</string>
  <!-- Message for the consent to download when using an on-device model. %s will be replaced by app name. -->
  <string name="mozac_summarize_download_nano_consent_message">En engangs-filhentning giver %s mulighed for at lave sammenfatninger af sider, som du har kontrol over.</string>
  <!-- Button text for the consent to download an on-device model approving download consent -->
  <string name="mozac_summarize_download_consent_button_positive">Hent for at sammenfatte</string>
  <!-- Button text for the consent to download an on-device model denying download consent -->
  <string name="mozac_summarize_download_consent_button_negative">Annuller</string>
  <!-- Title for the download in progress screen -->
  <string name="mozac_summarize_download_progress_title">Opsætter sammendrag</string>
  <!-- Message to describe that a download is in progress using an on-device, private model -->
  <string name="mozac_summarize_download_progress_message">Engangs-filhentning til private sammenfatninger.</string>
  <!-- Caption to describe the progress of the download. %1$.2f is bytes downloaded, %2$.2f is total bytes required for download to complete. -->
  <string name="mozac_summarize_download_progress_caption">%1$.2f MB / %2$.2f MB</string>
  <!-- Button text shown while a download is in progress to cancel the download -->
  <string name="mozac_summarize_download_progress_button_negative">Annuller</string>
  <!-- Title for the download error screen -->
  <string name="mozac_summarize_download_error_title">Fejl</string>
  <!-- Generic fallback message for the download error screen -->
  <string name="mozac_summarize_download_error_fallback_message">Ukendt fejl</string>
  <!-- Button for the download error screen to try again -->
  <string name="mozac_summarize_download_error_positive_button">Prøv igen</string>
  <!-- Button for the download error screen to cancel -->
  <string name="mozac_summarize_download_error_negative_button">Annuller</string>
  <!-- Title for the error screen when page is too long to summarize -->
  <string name="mozac_summarize_content_too_long_error_title">Siden er for lang til at sammenfatte</string>
  <!-- Title for the info error screen -->
  <string name="mozac_summarize_info_error_title">Kan ikke sammenfattte lige nu</string>
  <!-- Generic fallback message for the info error screen -->
  <string name="mozac_summarize_info_error_message">Prøv igen senere.</string>
  <!-- Error code shown on long press of the error icon. %1$d is an error code. -->
  <string name="mozac_summarize_info_error_code">Fejlkode: %1$d</string>
  <!-- Loading text displayed while a page summary is being generated -->
  <string name="mozac_feature_summarize_loading_title">Sammenfatter…</string>
  <!-- Content description for the settings icon button in the summarized view -->
  <string name="mozac_summarize_settings_button_content_description">Indstillinger for sammenfatning af sider</string>
  <!-- Title for the settings screen shown in the summarization bottom sheet -->
  <string name="mozac_summarize_settings_title">Sammenfatning af sider</string>
  <!-- Label for the summarize pages toggle in settings -->
  <string name="mozac_summarize_settings_summarize_pages">Sammenfat sider</string>
  <!-- Description for the summarize pages toggle -->
  <string name="mozac_summarize_settings_summarize_pages_cloud">Opret sammenfatninger af sider med AI. Sider og sammendrag forbliver private og gemmes aldrig.</string>
  <!-- Link text to learn more about page summaries in settings -->
  <string name="mozac_summarize_settings_learn_more">Læs mere</string>
  <!-- Section header for gesture settings -->
  <string name="mozac_summarize_settings_gestures">Bevægelser</string>
  <!-- Label for the shake to summarize toggle in settings -->
  <string name="mozac_summarize_settings_shake_to_summarize">Ryst for at sammenfatte</string>
  <!-- Description for the shake to summarize toggle in settings -->
  <string name="mozac_summarize_settings_shake_to_summarize_description">Ryst din enhed fra side til side for at sammenfatte en side.</string>
  <!-- Message for summary by model, %1$s is the name of the model that is being displayed -->
  <string name="mozac_feature_summarize_summary_model">Sammenfatning af %1$s</string>
  <!-- Disclaimer message -->
  <string name="mozac_feature_summarize_disclaimer_message">AI kan lave fejl</string>
  <!-- Title for the page summary AI controllable feature -->
  <string name="mozac_ai_controls_page_summary_title">Sammenfatning af sider</string>
  <!-- Description for the page summary AI controllable feature -->
  <string name="mozac_ai_controls_page_summary_description">Sider og sammenfatninger gemmes aldrig.</string>
  <!-- Button text for the Error dismiss button on Shake to Summarize -->
  <string name="mozac_summarize_error_dissmiss">Afvis</string>
</resources>
