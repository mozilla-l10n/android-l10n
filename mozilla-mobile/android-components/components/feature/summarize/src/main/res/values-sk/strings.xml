  <string name="mozac_summarize_settings_shake_to_summarize_description">Potraste zariadením zo strany na stranu, aby ste vytvorili súhrn stránky.</string>
  <!-- Message for summary by model, %1$s is the name of the model that is being displayed -->
  <string name="mozac_feature_summarize_summary_model">Súhrn stránky od %1$s</string>
  <!-- Disclaimer message -->
  <string name="mozac_feature_summarize_disclaimer_message">Umelá inteligencia môže robiť chyby</string>
  <!-- Title for the page summary AI controllable feature -->
  <string name="mozac_ai_controls_page_summary_title">Súhrny stránok</string>
  <!-- Description for the page summary AI controllable feature -->
  <string name="mozac_ai_controls_page_summary_description">Stránky a súhrny sa nikdy neukladajú.</string>
  <!-- Button text for the Error dismiss button on Shake to Summarize -->
  <string name="mozac_summarize_error_dissmiss">Zavrieť</string>
