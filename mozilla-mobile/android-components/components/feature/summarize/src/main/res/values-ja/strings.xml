  <string name="mozac_summarize_settings_summarize_pages_cloud">AI でページの要約を作成します。ページとその要約は非公開で、保存されることはありません。</string>
  <!-- Link text to learn more about page summaries in settings -->
  <string name="mozac_summarize_settings_learn_more">詳細情報</string>
  <!-- Section header for gesture settings -->
  <string name="mozac_summarize_settings_gestures">ジェスチャー</string>
  <!-- Label for the shake to summarize toggle in settings -->
  <string name="mozac_summarize_settings_shake_to_summarize">振って要約</string>
  <!-- Description for the shake to summarize toggle in settings -->
  <string name="mozac_summarize_settings_shake_to_summarize_description">端末を左右に振ってページを要約します。</string>
  <!-- Message for summary by model, %1$s is the name of the model that is being displayed -->
  <string name="mozac_feature_summarize_summary_model">%1$s による要約</string>
  <!-- Disclaimer message -->
  <string name="mozac_feature_summarize_disclaimer_message">AI はミスをする可能性があります</string>
  <!-- Title for the page summary AI controllable feature -->
  <string name="mozac_ai_controls_page_summary_title">ページ要約</string>
  <!-- Description for the page summary AI controllable feature -->
  <string name="mozac_ai_controls_page_summary_description">ページや要約は一切保存されません。</string>
  <!-- Button text for the Error dismiss button on Shake to Summarize -->
  <string name="mozac_summarize_error_dissmiss">閉じる</string>
</resources>
