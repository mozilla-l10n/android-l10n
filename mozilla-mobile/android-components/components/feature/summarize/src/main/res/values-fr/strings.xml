  <!-- Link text to learn more about page summaries in settings -->
  <string name="mozac_summarize_settings_learn_more">En savoir plus</string>
  <!-- Section header for gesture settings -->
  <string name="mozac_summarize_settings_gestures">Mouvements</string>
  <!-- Label for the shake to summarize toggle in settings -->
  <string name="mozac_summarize_settings_shake_to_summarize">Pour résumer, secouez</string>
