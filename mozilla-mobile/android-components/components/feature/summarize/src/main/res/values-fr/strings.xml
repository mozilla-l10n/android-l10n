  <string name="mozac_summarize_settings_shake_to_summarize_description">Secouez votre appareil d’un côté à l’autre pour résumer une page.</string>
  <!-- Message for summary by model, %1$s is the name of the model that is being displayed -->
  <string name="mozac_feature_summarize_summary_model">Résumé par %1$s</string>
  <!-- Disclaimer message -->
  <string name="mozac_feature_summarize_disclaimer_message">L’IA peut faire des erreurs</string>
  <!-- Title for the page summary AI controllable feature -->
  <string name="mozac_ai_controls_page_summary_title">Résumés de pages</string>
  <!-- Description for the page summary AI controllable feature -->
  <string name="mozac_ai_controls_page_summary_description">Les pages et les résumés ne sont jamais stockés.</string>
</resources>
