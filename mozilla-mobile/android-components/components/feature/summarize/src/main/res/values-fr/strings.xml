  <string name="mozac_summarize_download_progress_button_negative">Annuler</string>
  <!-- Title for the download error screen -->
  <string name="mozac_summarize_download_error_title">Erreur</string>
  <!-- Generic fallback message for the download error screen -->
  <string name="mozac_summarize_download_error_fallback_message">Erreur inconnue</string>
  <!-- Button for the download error screen to try again -->
  <string name="mozac_summarize_download_error_positive_button">Réessayer</string>
  <!-- Button for the download error screen to cancel -->
  <string name="mozac_summarize_download_error_negative_button">Annuler</string>
  <!-- Title for the error screen when page is too long to summarize -->
  <string name="mozac_summarize_content_too_long_error_title">Page trop longue pour être résumée</string>
